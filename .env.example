# StormeAI development environment
NODE_ENV=development

# App
APP_URL=http://localhost:5173
APP_NAME=StormeAI

# Ollama default AI provider
# VITE_* values are used by local dashboard Test Chat in the browser.
OLLAMA_BASE_URL=http://127.0.0.1:11434
VITE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="StormeAI <no-reply@stormeai.local>"

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=
# Figma
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
FIGMA_TEAM_ID=
FIGMA_PROJECT_ID=
